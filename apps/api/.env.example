NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Dev: postgresql://USER:PASS@localhost:5432/DB_NAME
# Prod: postgresql://USER:PASS@127.0.0.1:6432/DB_NAME?pgbouncer=true&connection_limit=1&connect_timeout=10
